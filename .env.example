# AIChecked.nl Chatbot — Environment Variables
# Copy this file to .env.local and fill in your values

# Required: OpenAI API Key
# Get yours at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Required: Resend API Key for chatbot notifications to info@aichecked.nl
# Get yours at: https://resend.com
RESEND_API_KEY=re_...

# Optional: Set to your production URL
NEXTAUTH_URL=https://www.aichecked.nl
